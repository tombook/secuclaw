// SecuClaw Database Schema (Phase 14: PostgreSQL 迁移)
// 设计原则：核心可查询字段强类型 + data Jsonb 存完整文档
// 时间戳从 epoch ms 转换为 DateTime，便于排序和范围查询
// 保留原始 epoch ms 在 data 字段中，确保与 JSON 文件存储完全兼容

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// 核心业务实体表（9 张表，覆盖 assets/vulnerabilities/incidents/
// threats/roles/users/tasks/compliance/audit-logs）
// ============================================

/// 资产库：assets.json（扁平结构）
model Asset {
  id          String   @id
  name        String   // 扁平字段：prod-web-01
  type        String?  // 扁平字段：server / database / network ...
  category    String?  // 扁平字段：production / staging / development
  environment String?  // 扁平字段：on-premise / cloud / hybrid
  criticality String?  // 提取自 business.criticality（critical / high / medium / low）
  owner       String?  // 提取自 business.owner
  status      String?  // 扁平字段：online / offline / maintenance ...
  exposureLevel String? // 提取自 security.exposureLevel
  createdAt   DateTime?
  updatedAt   DateTime?
  /// 完整资产文档（含 location/network/technology/business/security 等嵌套字段）
  data        Json

  @@index([type])
  @@index([category])
  @@index([criticality])
  @@index([status])
}

/// 漏洞库：vulnerabilities.json
model Vulnerability {
  id        String   @id
  cveId     String?  // 提取自 info.cveId
  title     String?  // 提取自 info.title
  severity  String?  // 提取自 info.cvss.severity（critical/high/medium/low/info）
  status    String?  // 提取自 remediation.status（open/in_progress/fixed/...）
  priority  Int?     // 提取自 remediation.priority（1-4）
  cvssScore Float?   // 提取自 info.cvss.score
  createdAt DateTime?
  updatedAt DateTime?
  /// 完整漏洞文档（含 info/affectedAssets/remediation/risk 等嵌套结构）
  data      Json

  @@index([severity])
  @@index([status])
  @@index([cveId])
}

/// 事件库：incidents.json
model Incident {
  id        String   @id
  ticketId  String?  // 工单编号 INC-2024-001
  title     String?  // 提取自 info.title
  severity  String?  // 提取自 info.severity（P0-P4）
  status    String?  // 提取自 workflow.status
  category  String?  // 提取自 info.category
  assignee  String?  // 提取自 workflow.assignee
  createdAt DateTime?
  updatedAt DateTime?
  /// 完整事件文档（含 info/timeline/sla/workflow/impact/attack/handlers）
  data      Json

  @@index([severity])
  @@index([status])
  @@index([ticketId])
  @@index([assignee])
}

/// 威胁库：threats.json
model Threat {
  id   String @id
  name String
  type String?  // nation-state / cybercrime / hacktivist / insider ...
  /// 完整威胁文档（含 aliases/capabilities/campaigns/targets/indicators/sources）
  data Json

  @@index([type])
  @@index([name])
}

/// 角色库：roles.json
model Role {
  id       String  @id
  name     String
  code     String?  // admin / ciso / security-expert ...
  level    Int?    // 权限级别（100/50/30...）
  isSystem Boolean @default(false)
  /// 完整角色文档（含 permissions[] 数组）
  data     Json

  @@index([code])
  @@index([level])
}

/// 用户库：users.json
model User {
  id          String   @id
  username    String
  email       String?
  displayName String?
  department  String?
  status      String?  // active / inactive / locked
  createdAt   DateTime?
  updatedAt   DateTime?
  /// 完整用户文档（含 roleIds[] / title / lastLogin）
  data        Json

  @@index([username])
  @@index([email])
  @@index([status])
}

/// 任务库：tasks.json
model Task {
  id         String   @id
  name       String?
  status     String?  // pending / running / completed / failed / cancelled
  priority   Int?
  ownerId    String?
  assigneeId String?
  createdAt  DateTime?
  updatedAt  DateTime?
  /// 完整任务文档（含 description/type/urgency/approval 等）
  data       Json

  @@index([status])
  @@index([ownerId])
  @@index([assigneeId])
}

/// 合规控制项库：compliance.json（扁平结构）
model Compliance {
  id            String   @id
  framework     String?  // GDPR / SOC 2 / ISO 27001 / PCI-DSS ...
  controlId     String?  // 控制项 ID（A.1 / CC1.1 ...）
  title         String?  // 控制项标题
  status        String?  // compliant / partial / non-compliant
  category      String?  // 分类（Principles / Access Control ...）
  lastAuditDate DateTime?
  nextAuditDate DateTime?
  /// 完整合规文档（含 titleCn/description/evidence/auditor/findings/remediation）
  data          Json

  @@index([framework])
  @@index([status])
  @@index([controlId])
}

/// 审计日志：audit-logs.json
model AuditLog {
  id         String   @id
  action     String?  // create / update / delete / configure / login ...
  resource   String?  // 操作的资源类型（system/incident/vulnerability ...）
  resourceId String?  // 资源 ID
  actor      String?  // 操作者（用户 ID 或 system）
  timestamp  DateTime?
  /// 完整审计日志文档（含 details 嵌套对象）
  data       Json

  @@index([action])
  @@index([resource, resourceId])
  @@index([timestamp])
  @@index([actor])
}
