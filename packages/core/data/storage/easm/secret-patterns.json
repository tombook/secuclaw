[
  {
    "type": "aws_access_key",
    "name": "AWS Access Key ID",
    "description": "Amazon Web Services Access Key ID (16 uppercase chars after AKIA prefix).",
    "regex": {
      "source": "\\bAKIA[0-9A-Z]{16}\\b",
      "flags": ""
    },
    "severity": "critical",
    "entropyThreshold": 0
  },
  {
    "type": "aws_secret_key",
    "name": "AWS Secret Access Key",
    "description": "40-character base64-like string isolated from alphanumerics.",
    "regex": {
      "source": "(?<![A-Za-z0-9])[A-Za-z0-9/+=]{40}(?![A-Za-z0-9])",
      "flags": ""
    },
    "severity": "high",
    "entropyThreshold": 3.5
  },
  {
    "type": "github_pat",
    "name": "GitHub Personal Access Token",
    "description": "GitHub classic personal access token (ghp_ prefix).",
    "regex": {
      "source": "\\bghp_[A-Za-z0-9]{36}\\b",
      "flags": ""
    },
    "severity": "high",
    "entropyThreshold": 0
  },
  {
    "type": "github_pat",
    "name": "GitHub Fine-Grained Token",
    "description": "GitHub fine-grained personal access token (github_pat_ prefix).",
    "regex": {
      "source": "\\bgithub_pat_[A-Za-z0-9_]{82}\\b",
      "flags": ""
    },
    "severity": "high",
    "entropyThreshold": 0
  },
  {
    "type": "gitlab_token",
    "name": "GitLab Personal Access Token",
    "description": "GitLab personal access token (glpat- prefix).",
    "regex": {
      "source": "\\bglpat-[A-Za-z0-9_\\-]{20,}\\b",
      "flags": ""
    },
    "severity": "high",
    "entropyThreshold": 0
  },
  {
    "type": "slack_token",
    "name": "Slack Token",
    "description": "Slack API token (xoxb, xoxp, xoxa, xoxr, xoxs prefix).",
    "regex": {
      "source": "\\bxox[abprs]-[A-Za-z0-9-]{10,}\\b",
      "flags": ""
    },
    "severity": "medium",
    "entropyThreshold": 0
  },
  {
    "type": "stripe_key",
    "name": "Stripe Live Secret Key",
    "description": "Stripe live secret API key (sk_live_ prefix).",
    "regex": {
      "source": "\\bsk_live_[A-Za-z0-9]{24,}\\b",
      "flags": ""
    },
    "severity": "critical",
    "entropyThreshold": 0
  },
  {
    "type": "api_key",
    "name": "Google API Key",
    "description": "Google Cloud API key (AIza prefix).",
    "regex": {
      "source": "\\bAIza[0-9A-Za-z_\\-]{35}\\b",
      "flags": ""
    },
    "severity": "medium",
    "entropyThreshold": 0
  },
  {
    "type": "jwt_secret",
    "name": "JSON Web Token",
    "description": "Encoded JWT with header.payload.signature segments.",
    "regex": {
      "source": "\\beyJ[A-Za-z0-9_=]+\\.[A-Za-z0-9_=]+\\.?[A-Za-z0-9_.+/=]*\\b",
      "flags": ""
    },
    "severity": "medium",
    "entropyThreshold": 0
  },
  {
    "type": "rsa_private_key",
    "name": "PEM Private Key",
    "description": "PEM-encoded private key (RSA, EC, DSA, OPENSSH, PGP).",
    "regex": {
      "source": "-----BEGIN [A-Z ]*PRIVATE KEY-----[\\s\\S]+?-----END",
      "flags": ""
    },
    "severity": "critical",
    "entropyThreshold": 0
  },
  {
    "type": "ssh_private_key",
    "name": "OpenSSH Private Key",
    "description": "OpenSSH-format private key header.",
    "regex": {
      "source": "-----BEGIN OPENSSH PRIVATE KEY-----[\\s\\S]+?-----END",
      "flags": ""
    },
    "severity": "critical",
    "entropyThreshold": 0
  },
  {
    "type": "database_url",
    "name": "Database Connection URL",
    "description": "Connection URL with embedded credentials (postgres, mysql, mongodb, redis).",
    "regex": {
      "source": "\\b(?:postgres|mysql|mongodb|redis):\\/\\/[^\\s]+:[^\\s]+@",
      "flags": ""
    },
    "severity": "high",
    "entropyThreshold": 0
  },
  {
    "type": "api_key",
    "name": "Generic API Key Assignment",
    "description": "Assignment or JSON-style declaration of an api_key/api-key.",
    "regex": {
      "source": "\\bapi[_-]?key['\":\\s]+['\"]?([A-Za-z0-9_\\-]{20,})",
      "flags": "i"
    },
    "severity": "medium",
    "entropyThreshold": 3
  },
  {
    "type": "stripe_key",
    "name": "Stripe Test Secret Key",
    "description": "Stripe test secret API key (sk_test_ prefix).",
    "regex": {
      "source": "\\bsk_test_[A-Za-z0-9]{24,}\\b",
      "flags": ""
    },
    "severity": "low",
    "entropyThreshold": 0
  },
  {
    "type": "password",
    "name": "Password in URL",
    "description": "Generic URL containing user:password@ credentials.",
    "regex": {
      "source": "\\b[a-zA-Z]+:\\/\\/[^:\\s]+:[^@\\s]+@",
      "flags": ""
    },
    "severity": "medium",
    "entropyThreshold": 0
  },
  {
    "type": "azure_sas",
    "name": "Azure Shared Access Signature",
    "description": "Azure Storage SAS URL with signature component.",
    "regex": {
      "source": "\\?sv=[\\d.]{4,}-[\\d.]{4,}&[^\"\\s]*sig=[A-Za-z0-9%]{20,}",
      "flags": ""
    },
    "severity": "critical",
    "entropyThreshold": 0
  },
  {
    "type": "oauth_client_secret",
    "name": "OAuth Client Secret Assignment",
    "description": "Assignment of an oauth client secret or client_secret.",
    "regex": {
      "source": "\\bclient[_-]?secret['\":\\s]+['\"]?([A-Za-z0-9_\\-]{20,})",
      "flags": "i"
    },
    "severity": "high",
    "entropyThreshold": 3
  }
]