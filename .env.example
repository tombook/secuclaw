NODE_ENV=production
PORT=21981
STORAGE_PATH=./data/storage
LOG_LEVEL=info

JWT_SECRET=replace-with-32-byte-random-base64-secret
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGINS=https://app.secuclaw.com,https://secuclaw.com
ALLOWED_HOSTS=app.secuclaw.com,secuclaw.com

LLM_PROVIDER=openai
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4-turbo
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_MS=30000

STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG....
SMTP_FROM=alerts@secuclaw.com
SMTP_FROM_NAME=SecuClaw Alerts

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
PAGERDUTY_INTEGRATION_KEY=...
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

RATE_LIMIT_PER_MINUTE=600
MAX_FILE_SIZE_MB=50
MAX_REQUEST_TIMEOUT_MS=30000

CACHE_ENABLED=true
CACHE_MAX_KEYS=1000
CACHE_TTL_MS=300000

AUDIT_LOG_RETENTION_DAYS=365
AUDIT_CHAIN_VERIFY_INTERVAL_HOURS=24
AUDIT_EXPORT_MAX_RECORDS=100000

BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=6
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=secuclaw-backups
BACKUP_S3_REGION=us-east-1
BACKUP_ENCRYPTION_KEY=replace-with-32-byte-base64

DATABASE_URL=postgresql://secuclaw:password@postgres:5432/secuclaw
DB_POOL_MAX=10
DB_MIGRATE_ON_BOOT=false
DUAL_WRITE_ENABLED=true
REDIS_URL=redis://redis:6379/0
REDIS_KEY_PREFIX=secuclaw:

GRAFANA_PASSWORD=replace-with-strong-password
PROMETHEUS_RETENTION_DAYS=30

ALERT_CRITICAL_WEBHOOK=https://alerts.secuclaw.com/critical
ALERT_HIGH_WEBHOOK=https://alerts.secuclaw.com/high

ENABLE_AI_AGENTS=true
ENABLE_AUTO_REMEDIATION=false
ENABLE_THREAT_HUNTING=true
ENABLE_MSSP_MULTI_TENANT=true

MULTI_TENANT_ENABLED=true
TENANT_ISOLATION_STRICT=true
TENANT_DEFAULT_TIER=professional

PRICING_FREE_USERS=3
PRICING_STARTER_USERS=10
PRICING_PROFESSIONAL_USERS=50
PRICING_ENTERPRISE_USERS=500
PRICING_MSSP_USERS=-1
